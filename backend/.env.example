# ── Base de datos ──
# Local (sin setup): SQLite. Déjalo así para desarrollo rápido.
DATABASE_URL=sqlite:///./appbit64.db
# Producción (Railway): descomenta y usa tu URL de PostgreSQL
# DATABASE_URL=postgresql://user:pass@host:5432/appbit64

# ── Agente IA (opcional) ──
# Sin GROQ_API_KEY el endpoint /datos responde en modo fallback.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── CORS ──
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://hackaton-bit.up.railway.app
